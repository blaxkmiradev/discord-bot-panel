<%
  const title = 'Files — ' + serverName;
  const activePage = 'files';
  const parentLink = currentPath
    ? `<a href="/files/${serverId}?path=${encodeURIComponent(parentPath)}" class="btn btn-sm btn-outline-secondary me-2"><i class="bi bi-arrow-up me-1"></i>Up</a>`
    : '';
  const crumbs = ['<a href="/">Dashboard</a>', `<a href="/servers/${serverId}">${serverName}</a>`, 'Files'];
  if (currentPath) {
    const parts = currentPath.split('/');
    let built = '';
    parts.forEach((p, i) => {
      built = built ? built + '/' + p : p;
      if (i < parts.length - 1) {
        crumbs.push(`<a href="/files/${serverId}?path=${encodeURIComponent(built)}">${p}</a>`);
      } else {
        crumbs.push(p);
      }
    });
  }
  const body = `
<div class="page-container">
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      ${crumbs.map((c, i) => `<li class="breadcrumb-item ${i === crumbs.length-1 ? 'active' : ''}">${c}</li>`).join('')}
    </ol>
  </nav>

  <div class="page-header d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-folder2-open me-2 text-warning"></i>File Manager</h5>
    <div class="d-flex gap-2 flex-wrap">
      ${parentLink}
      <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
        <i class="bi bi-cloud-upload me-1"></i>Upload
      </button>
      <button class="btn btn-sm btn-outline-success" data-bs-toggle="modal" data-bs-target="#newFileModal">
        <i class="bi bi-file-plus me-1"></i>New File
      </button>
      <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#newFolderModal">
        <i class="bi bi-folder-plus me-1"></i>New Folder
      </button>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
              <th>Name</th>
              <th class="d-none d-md-table-cell">Size</th>
              <th class="d-none d-md-table-cell">Modified</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            ${entries.length === 0 ? '<tr><td colspan="4" class="text-center text-muted py-4">Empty directory</td></tr>' : ''}
            ${entries.map(e => `
            <tr>
              <td>
                ${e.isDir
                  ? `<a href="/files/${serverId}?path=${encodeURIComponent(e.relPath)}" class="text-decoration-none">
                      <i class="bi bi-folder-fill text-warning me-2"></i><strong>${e.name}</strong>
                    </a>`
                  : `<a href="/files/${serverId}/edit?path=${encodeURIComponent(e.relPath)}" class="text-decoration-none">
                      <i class="bi bi-file-earmark-text me-2 text-info"></i>${e.name}
                    </a>`
                }
              </td>
              <td class="d-none d-md-table-cell text-muted small">${e.size}</td>
              <td class="d-none d-md-table-cell text-muted small">${e.mtime}</td>
              <td class="text-end">
                <div class="d-flex gap-1 justify-content-end">
                  ${!e.isDir ? `<a href="/files/${serverId}/edit?path=${encodeURIComponent(e.relPath)}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil-fill"></i></a>` : ''}
                  <button class="btn btn-sm btn-outline-danger" onclick="deleteEntry('${e.relPath.replace(/'/g,"\\\\'")}', ${e.isDir})">
                    <i class="bi bi-trash3-fill"></i>
                  </button>
                </div>
              </td>
            </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Upload Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="bi bi-cloud-upload me-2"></i>Upload File</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/files/${serverId}/upload" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="path" value="${currentPath}" />
        <div class="modal-body">
          <input type="file" name="file" class="form-control" required />
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-1"></i>Upload</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- New File Modal -->
<div class="modal fade" id="newFileModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="bi bi-file-plus me-2"></i>New File</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="text" id="newFileName" class="form-control" placeholder="filename.js" />
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-success" onclick="createFile()">Create</button>
      </div>
    </div>
  </div>
</div>

<!-- New Folder Modal -->
<div class="modal fade" id="newFolderModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="bi bi-folder-plus me-2"></i>New Folder</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="text" id="newFolderName" class="form-control" placeholder="folder-name" />
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-info text-white" onclick="createFolder()">Create</button>
      </div>
    </div>
  </div>
</div>
`;
%>

<%- include('layout', { title, activePage, body, user, extraScripts: `
<script>
const SERVER_ID = '${serverId}';
const CURRENT_PATH = '${currentPath}';

function deleteEntry(filePath, isDir) {
  if (!confirm('Delete ' + (isDir ? 'folder' : 'file') + ' "' + filePath + '"?' + (isDir ? ' (all contents will be deleted)' : ''))) return;
  fetch('/files/' + SERVER_ID + '/delete', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ filePath })
  }).then(r => r.json()).then(d => {
    if (d.success) location.reload();
    else alert('Error: ' + (d.message || 'Failed'));
  });
}

function createFile() {
  const fileName = document.getElementById('newFileName').value.trim();
  if (!fileName) return;
  fetch('/files/' + SERVER_ID + '/new-file', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ dirPath: CURRENT_PATH, fileName })
  }).then(r => r.json()).then(d => {
    if (d.success) location.reload();
    else alert('Error: ' + d.message);
  });
}

function createFolder() {
  const folderName = document.getElementById('newFolderName').value.trim();
  if (!folderName) return;
  fetch('/files/' + SERVER_ID + '/new-folder', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ dirPath: CURRENT_PATH, folderName })
  }).then(r => r.json()).then(d => {
    if (d.success) location.reload();
    else alert('Error: ' + d.message);
  });
}
</script>
` }) %>
