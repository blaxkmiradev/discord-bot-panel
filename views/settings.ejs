<%
  const title = 'Settings';
  const activePage = 'settings';
  const body = `
<div class="page-container">
  <div class="page-header mb-4">
    <h4 class="fw-bold"><i class="bi bi-gear-fill me-2 text-primary"></i>Panel Settings</h4>
    <p class="text-muted mb-0">Configure branding, credentials, and server limits</p>
  </div>

  ${flash ? `<div class="alert alert-success d-flex align-items-center gap-2"><i class="bi bi-check-circle-fill"></i><span>${flash}</span></div>` : ''}
  ${error ? `<div class="alert alert-danger d-flex align-items-center gap-2"><i class="bi bi-exclamation-triangle-fill"></i><span>${error}</span></div>` : ''}

  <div class="row g-4">

    <!-- General Settings -->
    <div class="col-12 col-lg-6">
      <div class="card">
        <div class="card-header bg-dark text-white">
          <i class="bi bi-palette me-2"></i>General / Branding
        </div>
        <div class="card-body">
          <form action="/settings/general" method="POST">
            <div class="mb-3">
              <label class="form-label fw-semibold">Site Name</label>
              <input type="text" name="siteName" class="form-control" value="${cfg.siteName || 'Bot Panel'}" placeholder="Bot Panel" />
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">Logo URL</label>
              <input type="text" name="logoUrl" class="form-control" value="${cfg.logoUrl || ''}" placeholder="/logo.png or https://..." />
              <div class="form-text">Enter a URL or upload a logo file below</div>
            </div>
            ${cfg.logoUrl ? `<div class="mb-3"><img src="${cfg.logoUrl}" alt="Current logo" class="img-thumbnail" style="max-height:80px" /></div>` : ''}
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save General</button>
          </form>

          <hr class="my-4" />

          <form action="/settings/logo" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
              <label class="form-label fw-semibold">Upload Logo</label>
              <input type="file" name="logo" class="form-control" accept="image/*" />
              <div class="form-text">PNG, JPG, GIF, SVG, WEBP (max 2MB)</div>
            </div>
            <button type="submit" class="btn btn-outline-primary"><i class="bi bi-upload me-1"></i>Upload Logo</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Admin Credentials -->
    <div class="col-12 col-lg-6">
      <div class="card">
        <div class="card-header bg-dark text-white">
          <i class="bi bi-shield-lock me-2"></i>Admin Credentials
        </div>
        <div class="card-body">
          <form action="/settings/credentials" method="POST">
            <div class="mb-3">
              <label class="form-label fw-semibold">Current Password</label>
              <input type="password" name="currentPass" class="form-control" required />
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">New Username (optional)</label>
              <input type="text" name="newUser" class="form-control" placeholder="Leave blank to keep current" />
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">New Password (optional)</label>
              <input type="password" name="newPass" class="form-control" placeholder="Leave blank to keep current" />
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">Confirm New Password</label>
              <input type="password" name="confirmPass" class="form-control" />
            </div>
            <button type="submit" class="btn btn-warning text-dark"><i class="bi bi-key me-1"></i>Change Credentials</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Server Limits -->
    <div class="col-12 col-lg-6">
      <div class="card">
        <div class="card-header bg-dark text-white">
          <i class="bi bi-sliders me-2"></i>Default Server Limits
        </div>
        <div class="card-body">
          <form action="/settings/limits" method="POST">
            <div class="mb-3">
              <label class="form-label fw-semibold"><i class="bi bi-memory me-1 text-warning"></i>Default RAM Limit (MB)</label>
              <input type="number" name="defaultRam" class="form-control" value="${panelData.serverLimits.defaultRam || 512}" min="64" max="8192" step="64" />
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold"><i class="bi bi-cpu me-1 text-info"></i>Default CPU Limit (%)</label>
              <input type="number" name="defaultCpu" class="form-control" value="${panelData.serverLimits.defaultCpu || 100}" min="10" max="100" />
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold"><i class="bi bi-people me-1 text-success"></i>Max Servers Per User</label>
              <input type="number" name="maxServersPerUser" class="form-control" value="${panelData.serverLimits.maxServersPerUser || 5}" min="1" max="50" />
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Limits</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Sub-Users -->
    <div class="col-12 col-lg-6">
      <div class="card">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
          <span><i class="bi bi-people me-2"></i>Sub-Users</span>
          <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
            <i class="bi bi-person-plus me-1"></i>Add User
          </button>
        </div>
        <div class="card-body">
          ${!panelData.users || panelData.users.length === 0 ? `
          <div class="text-center text-muted py-4">
            <i class="bi bi-people display-6 d-block mb-2"></i>
            <p class="mb-0">No sub-users yet. Create one to allow others to manage bots.</p>
          </div>
          ` : `
          <div class="table-responsive">
            <table class="table table-hover align-middle">
              <thead class="table-dark">
                <tr>
                  <th>Username</th>
                  <th>Max Servers</th>
                  <th>Max RAM</th>
                  <th>Created</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                ${panelData.users.map(u => `
                <tr>
                  <td><strong>${u.username}</strong></td>
                  <td>${u.maxServers}</td>
                  <td>${u.maxRam} MB</td>
                  <td class="text-muted small">${new Date(u.createdAt).toLocaleDateString()}</td>
                  <td class="text-end">
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteUser('${u.username}')">
                      <i class="bi bi-trash3-fill"></i>
                    </button>
                  </td>
                </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
          `}
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Create User Modal -->
<div class="modal fade" id="createUserModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Create Sub-User</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/settings/users/create" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label fw-semibold">Username</label>
            <input type="text" name="username" class="form-control" required />
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Password</label>
            <input type="password" name="password" class="form-control" required />
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Max Servers</label>
            <input type="number" name="maxServers" class="form-control" value="3" min="1" max="20" />
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Max RAM Per Server (MB)</label>
            <input type="number" name="maxRam" class="form-control" value="512" min="64" max="4096" step="64" />
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Create User</button>
        </div>
      </form>
    </div>
  </div>
</div>
`;
%>

<%- include('layout', { title, activePage, body, user, cfg, extraScripts: `
<script>
function deleteUser(username) {
  if (!confirm('Delete user "' + username + '"? This will NOT delete their servers.')) return;
  fetch('/settings/users/' + username + '/delete', { method: 'POST' })
    .then(r => r.json())
    .then(d => { if (d.success) location.reload(); });
}
</script>
` }) %>
