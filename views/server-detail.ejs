<%
  const title = meta.name;
  const activePage = 'server';
  const isRunning = status.status === 'running';
  const body = `
<div class="page-container">

  <!-- Breadcrumb -->
  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
      <li class="breadcrumb-item active">${meta.name}</li>
    </ol>
  </nav>

  <!-- Header -->
  <div class="page-header d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
    <div>
      <h4 class="mb-1 fw-bold">
        <i class="bi bi-discord me-2 text-primary"></i>${meta.name}
        <span class="badge ms-2 ${isRunning ? 'bg-success' : 'bg-secondary'} fs-6">
          ${isRunning ? 'Online' : 'Offline'}
        </span>
      </h4>
      <p class="text-muted mb-0 small">
        Entry: <code>${meta.entryPoint}</code>
        ${status.pid ? ' &bull; PID: ' + status.pid : ''}
        ${status.startTime ? ' &bull; Started: ' + new Date(status.startTime).toLocaleString() : ''}
      </p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <button class="btn btn-success" id="btnStart" onclick="serverAction('start')">
        <i class="bi bi-play-fill me-1"></i>Start
      </button>
      <button class="btn btn-warning" id="btnStop" onclick="serverAction('stop')">
        <i class="bi bi-stop-fill me-1"></i>Stop
      </button>
      <button class="btn btn-info text-white" id="btnRestart" onclick="serverAction('restart')">
        <i class="bi bi-arrow-repeat me-1"></i>Restart
      </button>
      <button class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
        <i class="bi bi-trash3-fill me-1"></i>Delete
      </button>
    </div>
  </div>

  <!-- Real-time Resource Stats -->
  ${isRunning ? `
  <div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
      <div class="card bg-info text-white">
        <div class="card-body py-3 px-3 text-center">
          <div class="small opacity-75 mb-1"><i class="bi bi-cpu me-1"></i>CPU Usage</div>
          <div class="h3 mb-0" id="liveCpu">--%</div>
          <div class="progress mt-2" style="height:4px">
            <div class="progress-bar bg-white" id="barCpu" style="width:0%"></div>
          </div>
          <div class="small mt-1">Limit: ${status.cpuLimit || meta.cpuLimit || 100}%</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="card bg-warning text-dark">
        <div class="card-body py-3 px-3 text-center">
          <div class="small opacity-75 mb-1"><i class="bi bi-memory me-1"></i>RAM Usage</div>
          <div class="h3 mb-0" id="liveMem">-- MB</div>
          <div class="progress mt-2" style="height:4px">
            <div class="progress-bar bg-dark" id="barMem" style="width:0%"></div>
          </div>
          <div class="small mt-1">Limit: ${status.ramLimit || meta.ramLimit || 512} MB</div>
        </div>
      </div>
    </div>
    <div class="col-6 col-md-4">
      <div class="card bg-secondary text-white">
        <div class="card-body py-3 px-3 text-center">
          <div class="small opacity-75 mb-1"><i class="bi bi-hdd me-1"></i>Storage</div>
          <div class="h3 mb-0" id="liveStorage">-- MB</div>
          <div class="small mt-1" id="fileCount">-- files</div>
        </div>
      </div>
    </div>
  </div>
  ` : ''}

  <div class="row g-3">

    <!-- Quick links -->
    <div class="col-12">
      <div class="d-flex gap-2 flex-wrap">
        <a href="/files/${serverId}" class="btn btn-outline-secondary">
          <i class="bi bi-folder2-open me-1"></i>File Manager
        </a>
        <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#npmModal">
          <i class="bi bi-box-seam me-1"></i>Install Package
        </button>
        <button class="btn btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#metaModal">
          <i class="bi bi-gear-fill me-1"></i>Settings & Limits
        </button>
      </div>
    </div>

    <!-- Real-time logs -->
    <div class="col-12">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center bg-dark text-white">
          <span><i class="bi bi-terminal-fill me-2"></i>Live Logs</span>
          <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-secondary" id="logStatus">Connecting...</span>
            <button class="btn btn-sm btn-outline-light" onclick="clearLogs()">Clear</button>
            <button class="btn btn-sm btn-outline-light" onclick="toggleAutoScroll()">
              <i class="bi bi-arrow-down-circle" id="autoScrollIcon"></i>
            </button>
          </div>
        </div>
        <div class="card-body p-0">
          <pre class="log-console" id="logConsole">${logs.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</pre>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Server</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>Are you sure you want to delete <strong>${meta.name}</strong>?</p>
        <p class="text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>This will permanently delete all files and cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <form action="/servers/${serverId}/delete" method="POST" class="d-inline">
          <button type="submit" class="btn btn-danger"><i class="bi bi-trash3-fill me-1"></i>Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- NPM Install Modal -->
<div class="modal fade" id="npmModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="bi bi-box-seam me-2"></i>Install NPM Package</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Package(s)</label>
          <input type="text" id="npmPackages" class="form-control" placeholder="discord.js dotenv" />
          <div class="form-text">Separate multiple packages with spaces</div>
        </div>
        <div class="bg-dark rounded p-2 text-light" id="npmOutput" style="min-height:60px;font-size:0.8rem;display:none;overflow-y:auto;max-height:200px;font-family:monospace;white-space:pre-wrap;"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary" onclick="installNpm()">
          <i class="bi bi-download me-1"></i>Install
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Settings/Meta Modal -->
<div class="modal fade" id="metaModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="bi bi-gear-fill me-2"></i>Server Settings & Limits</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Server Name</label>
          <input type="text" id="metaName" class="form-control" value="${meta.name}" />
        </div>
        <div class="mb-3">
          <label class="form-label">Entry Point</label>
          <input type="text" id="metaEntry" class="form-control" value="${meta.entryPoint}" />
        </div>
        <div class="row g-3">
          <div class="col-6">
            <label class="form-label fw-semibold"><i class="bi bi-memory me-1 text-warning"></i>RAM Limit (MB)</label>
            <input type="number" id="metaRam" class="form-control" value="${meta.ramLimit || 512}" min="64" max="8192" step="64" />
          </div>
          <div class="col-6">
            <label class="form-label fw-semibold"><i class="bi bi-cpu me-1 text-info"></i>CPU Limit (%)</label>
            <input type="number" id="metaCpu" class="form-control" value="${meta.cpuLimit || 100}" min="10" max="100" />
          </div>
        </div>
        <div class="form-text mt-2">Changes to limits apply on next start/restart</div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" onclick="saveMeta()">
          <i class="bi bi-save me-1"></i>Save
        </button>
      </div>
    </div>
  </div>
</div>
`;
%>

<%- include('layout', { title, activePage, body, user, cfg, extraScripts: `
<script>
const SERVER_ID = '${serverId}';
const socket = io();
let autoScroll = true;

socket.on('connect', () => {
  socket.emit('join-logs', SERVER_ID);
  document.getElementById('logStatus').textContent = 'Connected';
  document.getElementById('logStatus').className = 'badge bg-success';
});
socket.on('disconnect', () => {
  document.getElementById('logStatus').textContent = 'Disconnected';
  document.getElementById('logStatus').className = 'badge bg-danger';
});
socket.on('log-history', ({ logs }) => {
  const el = document.getElementById('logConsole');
  el.textContent = logs.join('\\n');
  if (autoScroll) el.scrollTop = el.scrollHeight;
});
socket.on('log', ({ data }) => {
  const el = document.getElementById('logConsole');
  el.textContent += (el.textContent ? '\\n' : '') + data;
  if (autoScroll) el.scrollTop = el.scrollHeight;
});
socket.on('server-status', (status) => {
  // Update live stats if this is our server
  if (document.getElementById('liveCpu')) {
    document.getElementById('liveCpu').textContent = (status.cpu || 0).toFixed(1) + '%';
    document.getElementById('barCpu').style.width = Math.min(status.cpu || 0, 100) + '%';
    document.getElementById('liveMem').textContent = (status.mem || 0).toFixed(0) + ' MB';
    const memPercent = ((status.mem || 0) / (status.ramLimit || 512)) * 100;
    document.getElementById('barMem').style.width = Math.min(memPercent, 100) + '%';
  }
});
socket.on('npm-log', ({ line }) => {
  const el = document.getElementById('npmOutput');
  el.style.display = 'block';
  el.textContent += line + '\\n';
  el.scrollTop = el.scrollHeight;
});
socket.on('npm-done', ({ code, msg }) => {
  const el = document.getElementById('npmOutput');
  el.textContent += '\\n✓ ' + msg;
});

// Poll for storage stats
setInterval(() => {
  fetch('/servers/' + SERVER_ID + '/status')
    .then(r => r.json())
    .then(s => {
      if (document.getElementById('liveStorage')) {
        document.getElementById('liveStorage').textContent = (s.mem || 0).toFixed(0) + ' MB';
      }
    });
  // Could add file count via separate API
}, 3000);

function clearLogs() {
  document.getElementById('logConsole').textContent = '';
}

function toggleAutoScroll() {
  autoScroll = !autoScroll;
  const icon = document.getElementById('autoScrollIcon');
  icon.className = autoScroll ? 'bi bi-arrow-down-circle-fill' : 'bi bi-arrow-down-circle';
}

function serverAction(action) {
  fetch('/servers/' + SERVER_ID + '/' + action, { method: 'POST' })
    .then(r => r.json())
    .then(d => {
      showToast(d.message || (d.success ? 'Done' : 'Error'), d.success ? 'success' : 'danger');
      if (d.success && action !== 'restart') setTimeout(() => location.reload(), 1200);
    });
}

function installNpm() {
  const pkg = document.getElementById('npmPackages').value.trim();
  if (!pkg) return;
  document.getElementById('npmOutput').style.display = 'block';
  document.getElementById('npmOutput').textContent = 'Running npm install ' + pkg + '...\\n';
  fetch('/servers/' + SERVER_ID + '/npm', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ packages: pkg })
  }).then(r => r.json()).then(d => {
    if (!d.success) document.getElementById('npmOutput').textContent += '\\nError: ' + d.message;
  });
}

function saveMeta() {
  const name = document.getElementById('metaName').value;
  const entryPoint = document.getElementById('metaEntry').value;
  const ramLimit = document.getElementById('metaRam').value;
  const cpuLimit = document.getElementById('metaCpu').value;
  fetch('/servers/' + SERVER_ID + '/meta', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name, entryPoint, ramLimit, cpuLimit })
  }).then(r => r.json()).then(d => {
    if (d.success) { bootstrap.Modal.getInstance(document.getElementById('metaModal')).hide(); showToast('Settings saved!'); }
  });
}

function showToast(msg, type) {
  const el = document.createElement('div');
  el.className = 'toast-notification toast bg-' + type + ' text-white show';
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 3000);
}
</script>
` }) %>
