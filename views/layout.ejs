<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %><%= cfg.siteName || 'Bot Panel' %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

<!-- Sidebar (desktop) -->
<div class="sidebar d-none d-md-flex flex-column">
  <div class="sidebar-brand">
    <% if (cfg.logoUrl) { %>
      <img src="<%= cfg.logoUrl %>" alt="logo" class="sidebar-logo me-2" />
    <% } else { %>
      <i class="bi bi-robot me-2"></i>
    <% } %>
    <%= cfg.siteName || 'Bot Panel' %>
  </div>
  <nav class="sidebar-nav flex-grow-1">
    <a href="/" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
      <i class="bi bi-grid-1x2-fill me-2"></i> Dashboard
    </a>
    <a href="#" class="sidebar-link" data-bs-toggle="modal" data-bs-target="#createModal">
      <i class="bi bi-plus-circle-fill me-2"></i> New Server
    </a>
    <a href="/settings" class="sidebar-link <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>">
      <i class="bi bi-gear-fill me-2"></i> Settings
    </a>
  </nav>
  <div class="sidebar-footer">
    <span class="text-muted small"><i class="bi bi-person-circle me-1"></i><%= typeof user !== 'undefined' ? user : 'Admin' %></span>
    <a href="/logout" class="btn btn-sm btn-outline-secondary ms-auto">Logout</a>
  </div>
</div>

<!-- Top bar (mobile) -->
<nav class="navbar navbar-dark bg-dark d-md-none sticky-top">
  <div class="container-fluid">
    <span class="navbar-brand fw-bold">
      <% if (cfg.logoUrl) { %><img src="<%= cfg.logoUrl %>" alt="logo" height="24" class="me-2" /><% } else { %><i class="bi bi-robot me-2"></i><% } %>
      <%= cfg.siteName || 'Bot Panel' %>
    </span>
    <div class="d-flex align-items-center gap-2">
      <span class="text-light small"><i class="bi bi-person-circle"></i> <%= typeof user !== 'undefined' ? user : 'Admin' %></span>
      <a href="/logout" class="btn btn-sm btn-outline-light">Logout</a>
    </div>
  </div>
</nav>

<!-- Main content -->
<div class="main-content">
  <%- body %>
</div>

<!-- Bottom nav (mobile) -->
<nav class="bottom-nav d-md-none">
  <a href="/" class="bottom-nav-item <%= typeof activePage !== 'undefined' && activePage === 'dashboard' ? 'active' : '' %>">
    <i class="bi bi-grid-1x2-fill"></i>
    <span>Dashboard</span>
  </a>
  <a href="#" class="bottom-nav-item" data-bs-toggle="modal" data-bs-target="#createModal">
    <i class="bi bi-plus-circle-fill"></i>
    <span>New Bot</span>
  </a>
  <a href="/settings" class="bottom-nav-item <%= typeof activePage !== 'undefined' && activePage === 'settings' ? 'active' : '' %>">
    <i class="bi bi-gear-fill"></i>
    <span>Settings</span>
  </a>
</nav>

<!-- Create Server Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header bg-dark text-white">
        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Create New Bot Server</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/servers/create" method="POST" enctype="multipart/form-data">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Server Name <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control" placeholder="My Discord Bot" required />
            </div>
            <div class="col-12 col-md-6">
              <label class="form-label fw-semibold">Entry Point</label>
              <input type="text" name="entryPoint" class="form-control" value="index.js" placeholder="index.js" />
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label fw-semibold"><i class="bi bi-memory me-1 text-warning"></i>RAM Limit (MB)</label>
              <input type="number" name="ramLimit" class="form-control" value="512" min="64" max="8192" step="64" />
              <div class="form-text">Max memory for this bot</div>
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label fw-semibold"><i class="bi bi-cpu me-1 text-info"></i>CPU Limit (%)</label>
              <input type="number" name="cpuLimit" class="form-control" value="100" min="10" max="100" />
              <div class="form-text">Max CPU usage %</div>
            </div>
            <div class="col-12 col-md-4">
              <label class="form-label fw-semibold"><i class="bi bi-hdd me-1 text-success"></i>Upload ZIP</label>
              <input type="file" name="botZip" class="form-control" accept=".zip" />
              <div class="form-text">Optional bot files</div>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Create Server</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.socket.io/4.6.0/socket.io.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="/js/app.js"></script>
<%- typeof extraScripts !== 'undefined' ? extraScripts : '' %>
</body>
</html>
